# Copy this file to .env and fill in real values.
# Never commit the .env file itself.

# PostgreSQL connection string (required)
DATABASE_URL=postgres://user:password@localhost:5432/go2shiny?sslmode=disable

# HTTP server port (default: 8080)
PORT=8080

# Log level: debug | info | warn | error (default: info)
LOG_LEVEL=info

# pgxpool maximum connections (default: 10)
MAX_DB_CONNS=10

# In-memory cache TTL in seconds for KPI/summary queries (default: 300)
CACHE_TTL_SECONDS=300
